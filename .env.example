# Variabili ambiente per l'ambiente di sviluppo locale.
# Copia questo file in `.env` (NON committato) e adatta i valori se necessario.
# In produzione si usa invece `.env.prod` (vedi `.env.prod.example`).

DJANGO_SECRET_KEY=dev-not-secret-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=velora.local,localhost,127.0.0.1
DATABASE_URL=sqlite:///data/db.sqlite3

# Variabile di ambiente che l'entrypoint legge per scegliere fra runserver e gunicorn.
DJANGO_ENV=dev
