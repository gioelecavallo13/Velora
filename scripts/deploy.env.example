# Copiare in scripts/deploy.env e valorizzare (scripts/deploy.env è in .gitignore).
# Stile progetto Sondaggi: DEPLOY_* per rsync / ssh; VPS_* sintetizza DEPLOY_HOST se omesso.

# Obbligatorio: user@hostname (scp/rsync destinazione)
DEPLOY_HOST=ubuntu@203.0.113.10
# Percorso assoluto sul server (uguale DOCKER_COMPOSE_PATH se preferisci questo nome)
DEPLOY_PATH=/opt/velora

SSH_USER=ubuntu
# Usato solo se DEPLOY_HOST non è impostato (costruisce ubuntu@IP)
VPS_HOST=203.0.113.10
VPS_IP=203.0.113.10

DOMAIN=velora.example.com

PROJECT_NAME=velora
DOCKER_COMPOSE_PATH=/opt/velora

TRAEFIK_NETWORK=rete_per_instradamento

# Opzionale
# SSH_PORT=22
# SSH_IDENTITY_FILE=/path/to/key.pem
# USE_SUDO_DOCKER=false
