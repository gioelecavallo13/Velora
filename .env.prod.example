# Variabili ambiente per l'ambiente di PRODUZIONE.
#
# Copia questo file in `.env.prod` (NON committato, vedi .gitignore) e
# adatta i valori. Il file `.env.prod` reale contiene segreti: NON committarlo
# mai e ruota le credenziali in caso di esposizione.
#
# Generazione SECRET_KEY:
#     python -c "import secrets; print(secrets.token_urlsafe(64))"

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------

# Chiave di firma di Django. Lunga, casuale, mai pubblicata. Cambiarla
# invalida sessioni esistenti.
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# DEBUG = 0 in produzione, sempre. Evita stacktrace pubblici e disabilita
# vari shortcut di sviluppo.
DJANGO_DEBUG=0

# Lista degli host accettati separati da virgola. Esempi:
#   - velora.example.com
#   - velora.example.com,www.velora.example.com
# Includere anche `web` se altri container compose devono parlare al server.
DJANGO_ALLOWED_HOSTS=velora.example.com

# `prod` -> entrypoint avvia gunicorn dopo collectstatic + migrate.
DJANGO_ENV=prod

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------

# Credenziali del servizio `db`. Postgres richiede POSTGRES_PASSWORD non vuoto.
POSTGRES_USER=velora
POSTGRES_PASSWORD=replace-me-with-a-strong-password
POSTGRES_DB=velora

# URL letta da Django (django-environ). L'host `db` corrisponde al nome del
# servizio nello stesso docker-compose.prod.yml.
DATABASE_URL=postgres://velora:replace-me-with-a-strong-password@db:5432/velora

# ---------------------------------------------------------------------------
# Gunicorn (web)
# ---------------------------------------------------------------------------

# Numero di worker. Regola di partenza: (2 x core CPU) + 1.
GUNICORN_WORKERS=3

# Timeout per richiesta (secondi). Aumentare se ci sono operazioni lunghe.
GUNICORN_TIMEOUT=30

# Riavvio graceful dei worker dopo N richieste (memory bloat protection).
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=50

# ---------------------------------------------------------------------------
# Nginx (porte host)
# ---------------------------------------------------------------------------

# Porte esposte sull'host. Cambiarle se le 80/443 sono gia` occupate o se
# c'e` un load balancer davanti.
NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443  # decommentare quando si attiva TLS
